{
  "name": "the-prototype-shelf",
  "version": "0.1.0",
  "description": "Landing page for in-flight design prototypes.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build --mode gh-pages && gh-pages -d dist --nojekyll",
    "build:soma-pages": "vite build --mode soma-pages",
    "deploy:soma": "npm run build:soma-pages && gh-pages -d dist --nojekyll --repo git@git.soma.salesforce.com:sabarish-ks/the-prototype-shelf.git"
  },
  "dependencies": {
    "lwc": "^9.0.2"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "vite": "^7.3.1",
    "vite-plugin-lwc": "^4.1.0"
  }
}
